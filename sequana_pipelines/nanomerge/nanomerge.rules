"""nanomerge pipeline

Author: Sequana Developers

This pipeline is part of Sequana project (sequana.readthedocs.io)

Execution:
1. prepare the pipelie:

    sequana_nanomerge --help

2. exceute it either manually:

    snakemake -s nanomerge.rules --forceall --stats stats.txt --cores 4

or following the instructions from step 1.
"""

from pathlib import Path
import pandas as pd
from sequana_pipetools import snaketools as sm

# This must be defined before the include
configfile: "config.yaml"


# A convenient manager
manager = sm.PipelineManager("nanomerge", config)

localrules: rulegraph, dot2svg

# convenient aliases
input_directory = Path(config["input_directory"])
input_pattern = config["input_pattern"]


# infer barcoded directories
barcodes = [x.name for x in input_directory.glob("*") if x.is_dir()]

class Sample():

    def __init__(self, samplesheet, barcoded):
        self.df = pd.read_csv(samplesheet)
        self.barcoded = barcoded
        if "sample" not in self.df.columns:
            self.df['sample'] = self.df['samplename']

    def get_barcode_from_sample(self, sample):
        candidate = self.df.query("sample==@sample")['barcode'].values[0]
        return candidate

    def get_projects(self):
        return self.df.project.unique()


import os
_samplesheet = config['samplesheet']
if not os.path.isabs(_samplesheet):
    _samplesheet = os.path.join(workflow.basedir, _samplesheet)

if len(barcodes) == 0:
    samples = Sample(_samplesheet, barcoded=False)
else:
    samples = Sample(_samplesheet, barcoded=True)


if config["summary"]:
    qc_file = ["pyco/pyco.html"]
else:
    qc_file = []

# ========================================================================= pipeline starts here
expected_fastqs = expand("{project}/{sample}.fastq.gz", zip, project=samples.df['project'],
        sample=samples.df['sample'])


if "barcode" in samples.df.columns and config["summary"]:
    rule pipeline:
        input:
            expected_fastqs,
            svg = ".sequana/rulegraph.svg",
            html="summary.html",
            subsummary=expand("pycoqc/{barcode}_summary.html", barcode=samples.df.barcode.values)
else:
    rule pipeline:
        input:
            expected_fastqs,
            html="summary.html",
            svg = ".sequana/rulegraph.svg",


def get_input_merge(wildcards):
    if samples.barcoded:
        barcode = samples.get_barcode_from_sample(wildcards.sample)
        filenames = list((input_directory / barcode).glob("*.fastq.gz"))
    else:
        filenames = list((input_directory).glob(input_pattern))
    return filenames

def get_input_directory(wildcards):
    if samples.barcoded:
        barcode = samples.get_barcode_from_sample(wildcards.sample)
        return input_directory / barcode
    else:
        return input_directory


if config["summary"]:


    rule sub_sample_summary:
        input:
            config['summary']
        output:
            "sub_sample_summary/summary.txt"
        params:
            percentage=config['sub_sample_summary']['percentage'] / 100,
            binning = 100
        run:

            import pandas as pd
            from pylab import linspace

            # We need the min and max first of the entire start time vector
            max_time = 0.
            min_time = 24 * 10 * 3600 #(10 days is enough. runs are expected to be 72 hours max)
            Ntotal = 0
            with pd.read_csv(input[0], chunksize=10000, sep='\t') as reader:
                for i, chunk in enumerate(reader):
                    max_time = max(max_time, chunk.start_time.max())
                    min_time = min(min_time, chunk.start_time.min())
                    Ntotal += len(chunk)

            bins = linspace(min_time, max_time, params.binning + 1)

            # now we perform the stratified histogram
            with pd.read_csv(input[0], chunksize=10000, sep="\t") as reader:

                # we'll save the header once
                header = True

                # go through all chunks
                for i,chunk in enumerate(reader):

                    # save rows based on stratified sampling
                    for j in range(params.binning-1):
                        X1, X2 = bins[j], bins[j+1]
                        subdf = chunk.query("start_time>=@X1 and start_time<@X2").sample(frac=params.percentage)
                        if header is True:
                            subdf.to_csv(output[0], header=True, mode="w", index=False, sep='\t')
                            header = False
                        else:
                            subdf.to_csv(output[0], header=False, mode="a+", index=False, sep='\t')

    rule pyco:
        input:
            "sub_sample_summary/summary.txt"
        output:
            "pyco/pyco.html"
        log:
            "pyco/pyco.log"
        params:
           options=config["pycoqc"]["options"]
        container:
            config["apptainers"]["pycoqc"]
        shell:
            """
            pycoQC --summary_file {input} -o {output} {params.options} > {log} 2>&1
            """

    if "barcode" in samples.df.columns:
        rule split_barcode:
            input: "sub_sample_summary/summary.txt"
            output: expand("sub_sample_summary/{barcode}_summary.txt", barcode=samples.df.barcode)
            run:
                import pandas as pd

                headers = {}
                for barcode in samples.df.barcode:
                    headers[barcode] = True

                # read header once so we can emit header-only files for barcodes with no reads
                header_line = pd.read_csv(input[0], sep="\t", nrows=0).columns.tolist()

                with pd.read_csv(input[0], chunksize=100000, sep="\t") as reader:

                    for i,chunk in enumerate(reader):
                        for barcode in samples.df.barcode:
                            filename= f"sub_sample_summary/{barcode}_summary.txt"
                            subdf = chunk.query("alias==@barcode")
                            if len(subdf):
                                if headers[barcode] is True:
                                    subdf.to_csv(filename, header=True, mode="w", index=False, sep='\t')
                                    headers[barcode] = False
                                else:
                                    subdf.to_csv(filename, header=False, mode="a+", index=False, sep='\t')

                # guarantee every declared output exists (pycoQC and snakemake both need it,
                # even when a barcode had no reads in the summary file)
                for barcode in samples.df.barcode:
                    filename = f"sub_sample_summary/{barcode}_summary.txt"
                    if headers[barcode] is True:
                        pd.DataFrame(columns=header_line).to_csv(filename, index=False, sep='\t')

        rule pycoqc_per_barcode:
            input:
                "sub_sample_summary/{barcode}_summary.txt"
            output:
                "pycoqc/{barcode}_summary.html"
            log:
                "pycoqc/{barcode}.log"
            params:
                options=config["pycoqc"]["options"]
            container:
                config["apptainers"]["pycoqc"]
            shell:
                r"""
                BANNER='<div style="background:#2d3748;color:#fff;padding:10px 20px;font-family:sans-serif;margin-bottom:15px;"><a href="../summary.html" style="color:#fff;text-decoration:none;font-weight:bold;">&larr; Back to summary</a> &nbsp;|&nbsp; <span style="font-size:1.1em;">pycoQC report &mdash; barcode {wildcards.barcode}</span></div>'
                if [ $(wc -l < {input}) -le 1 ]; then
                    echo "No reads for barcode {wildcards.barcode}; generating placeholder report." > {log}
                    printf '<html><head><title>pycoQC - %s</title></head><body>%s<p style="padding:20px;">No reads were assigned to this barcode in the (sub-sampled) sequencing summary.</p></body></html>\n' "{wildcards.barcode}" "$BANNER" > {output}
                else
                    pycoQC --summary_file {input} -o {output} {params.options} > {log} 2>&1
                    # inject back-to-summary banner just after <body>
                    sed -i "0,/<body[^>]*>/s||&${{BANNER}}|" {output}
                fi
                """


        


rule merge:
    input:
        get_input_merge
    output:
        "{project}/{sample}.fastq.gz"
    wildcard_constraints:
        project="[^/]+",
        sample="[^/]+"
    params:
        indir=get_input_directory
    shell:
        """
        find {params.indir} -type f -name "*fastq.gz" -exec cat {{}} + > {output}
        """


rule rulegraph:
    input:
        workflow.snakefile
    output:
        "rulegraph/rulegraph.dot"
    params:
        configname = "config.yaml",
        required_local_files = ["schema.yaml", config['samplesheet']] + ([config['summary']] if config.get('summary') else [])
    run:
        manager.get_run("rulegraph/run", "v1")(input, output, params)


rule dot2svg:
    input:
        "rulegraph/rulegraph.dot"
    output:
        ".sequana/rulegraph.svg"
    container:
        config['apptainers']['graphviz']
    shell:
        manager.get_shell("graphviz/dot2svg", "v1")



rule html_report:
    input:
        list(expected_fastqs) + qc_file
    output:
        "summary.html"
    run:
        from sequana.modules_report.summary import SequanaReport
        from sequana_pipelines import nanomerge
        os.makedirs("images", exist_ok=True)

        data = manager.getmetadata()

        projects = list(samples.get_projects())
        dirs = ", ".join([f'<a href="{x}/">{x}</a>' for x in projects])
        n_samples = len(samples.df)
        mode = "barcoded" if samples.barcoded else "non-barcoded"
        input_dir_html = f'<code>{config["input_directory"]}</code>'

        def get_stats():
            from sequana import FastQ
            from sequana.stats import N50
            from pylab import mean
            from collections import defaultdict

            lengths = defaultdict(list)

            for sample, filename in manager.samples.items():
                barcode = filename.split("/")[-2]
                barcodes.append(barcode)
                f = FastQ(filename)

                # keep track of all lengths
                these_lengths = f.get_lengths()
                lengths[barcode].extend(these_lengths)

            mus = {}
            N50s = {}
            nreads = {}
            sample_names = {}
            projects = {}
            for barcode in lengths.keys():
                mus[barcode] = round(mean(lengths[barcode]), 0)
                N50s[barcode] = N50(lengths[barcode])
                nreads[barcode] = len(lengths[barcode])
                try:
                    row = samples.df.query("barcode==@barcode").iloc[0]
                    sample_names[barcode] = row['sample']
                    projects[barcode] = row['project']
                except Exception:
                    sample_names[barcode] = "undefined"
                    projects[barcode] = "undefined"

            # a summary table
            keys = sorted(sample_names.keys())
            df = pd.DataFrame({
                "sample": [sample_names[k] for k in keys],
                "project": [projects[k] for k in keys],
                "barcode": keys,
                "N50": [N50s[k] for k in keys],
                "mean read length": [mus[k] for k in keys],
                "Number of reads": [nreads[k] for k in keys],
            })

            # per-barcode pycoQC link (only when it is actually produced)
            has_links = "barcode" in samples.df.columns and config.get("summary")
            if has_links:
                df['link'] = [
                    f"pycoqc/{b}_summary.html" if b in samples.df.barcode.values else ""
                    for b in df.barcode.values
                ]


            total_reads = sum([nreads[k] for k in nreads.keys()])

            from sequana.utils.datatables_js import DataTable
            datatable = DataTable(df, 'nanomerge', index=False)
            datatable.datatable.datatable_options = {'paging': 'false',
                                          'buttons': ['copy', 'csv'],
                                          'bSort': 'true',
                                          'dom':"RSPrtp"
                                        }

            # add link to the per-barcode pycoQC report
            if has_links:
                datatable.datatable.set_links_to_column('link', 'sample')

            js = datatable.create_javascript_function()
            htmltable = datatable.create_datatable()

            return js + htmltable, total_reads


        htmltable, total_reads = get_stats()


        def get_model():
            from sequana import FastA
            s = next(FastA(input[0]))
            try:
                model = [x.split("=")[1] for x in s.comment.split() if "model_version_id" in x][0]
            except (IndexError, AttributeError):
                model = "unknown"
            return model

        model = get_model()

        general_info = f"""
<h2>General Information</h2>
<ul>
    <li><b>Input directory:</b> {input_dir_html}</li>
    <li><b>Run mode:</b> {mode}</li>
    <li><b>Number of samples:</b> {n_samples}</li>
    <li><b>Project directories:</b> {dirs}</li>
    <li><b>Base-calling model:</b> {model}</li>
    <li><b>Total reads (after filtering):</b> {total_reads:,}</li>
</ul>
<p>Merged FASTQ files are available in the project directories listed above.
The table below summarises per-sample read counts, N50, and mean read length.
{'Click a sample name to open its pycoQC report.' if samples.barcoded and config['summary'] else ''}</p>
"""

        if config['summary']:
            # sub-sampling warning
            percentage = config['sub_sample_summary']['percentage'] / 100
            if percentage == 1:
                subsample = ""
            else:
                ratio = round(1 / percentage, 2)
                subsample = (
                    f'<p style="color:#b00"><b>Note:</b> sub-sampling was performed '
                    f'({percentage*100:.0f}% of the sequencing summary used). '
                    f'Multiply the pycoQC numbers by ~{ratio} for full-run estimates.</p>'
                )

            with open("pyco/pyco.html", "r") as fout:
                pycodata = fout.read()
                pycodata = '<div class="columns">' + pycodata.split('<div class="columns">')[-1].replace("</div>\n</body>\n</html>", "")

            s = SequanaReport(
                data,
                general_info + htmltable + "<hr><h2>Quality Control (pycoQC)</h2>" + subsample + pycodata,
            )
        else:
            s = SequanaReport(
                data,
                general_info + htmltable + "<p><i>No sequencing_summary file was provided; pycoQC report skipped.</i></p>",
            )



# ======================================================================================== rulegraph


onsuccess:

    print("Once done, please clean up the directory using\n'make clean'")

    manager.teardown(extra_files_to_remove=["pyco/pyco.log", "pyco/pyco.html"])


    shell("chmod -R g+w .")
    shell("rm -rf pyco rulegraph")

onerror:
    manager.onerror()
